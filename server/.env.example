# copy this layout to .env and fill in the values
PORT=3000
# Optional: comma-separated browser origins when the SPA calls the API cross-origin (omit if Apache proxies /api on the same host).
# CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=your_jwt_secret_here
ORACLE_HOST=localhost
ORACLE_PORT=1539
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USER=guest
ORACLE_PASSWORD=your_oracle_password_here
ORACLE_CONNECTION_STRING=username/password@host:port/service_name
