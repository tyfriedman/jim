# Leave empty for same-origin /api (Vite dev proxy or Apache reverse proxy).
# Set full API base if the SPA and API are on different origins, e.g.:
# VITE_API_BASE_URL=https://api.example.com/api
VITE_API_BASE_URL=
# For local Vite proxy; should match server PORT in server/.env.
VITE_API_PROXY_TARGET=http://localhost:3000
